{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "InvoraLite",
  "version": "1.0.0",
  "identifier": "com.edp.invora",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "InvoraLite 1.0.0",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "base-uri": "'self'",
        "object-src": "'none'",
        "connect-src": [
          "'self'",
          "ipc:",
          "http://ipc.localhost",
          "https://api.dicebear.com",
          "https://github.com",
          "https://*.github.com",
          "https://objects.githubusercontent.com",
          "https://release-assets.githubusercontent.com"
        ],
        "img-src": [
          "'self'",
          "asset:",
          "http://asset.localhost",
          "blob:",
          "data:",
          "https://api.dicebear.com"
        ],
        "style-src": [
          "'self'",
          "https://fonts.googleapis.com"
        ],
        "font-src": [
          "'self'",
          "https://fonts.gstatic.com",
          "data:"
        ],
        "script-src": "'self'"
      },
      "devCsp": {
        "default-src": "'self'",
        "base-uri": "'self'",
        "object-src": "'none'",
        "connect-src": [
          "'self'",
          "ipc:",
          "http://ipc.localhost",
          "http://localhost:1420",
          "ws://localhost:1420",
          "https://api.dicebear.com",
          "https://github.com",
          "https://*.github.com",
          "https://objects.githubusercontent.com",
          "https://release-assets.githubusercontent.com"
        ],
        "img-src": [
          "'self'",
          "asset:",
          "http://asset.localhost",
          "blob:",
          "data:",
          "https://api.dicebear.com"
        ],
        "style-src": [
          "'self'",
          "'unsafe-inline'",
          "https://fonts.googleapis.com"
        ],
        "font-src": [
          "'self'",
          "https://fonts.gstatic.com",
          "data:"
        ],
        "script-src": [
          "'self'",
          "'unsafe-eval'",
          "'unsafe-inline'"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis"
    ],
    "licenseFile": "EULA.txt",
    "copyright": "Copyright © 2026 Gyan B. Baraily",
    "publisher": "Gyan B. Baraily",
    "shortDescription": "Offline inventory and retail management for Windows",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "template": "windows/installer.nsi",
        "installerHooks": "windows/installer-hooks.nsh",
        "sidebarImage": "windows/installer-bg-split.bmp",
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg0RkVGNkQ4QzZGRDlCMDAKUldRQW0vM0cyUGIraEk2M2dWMlQ4aU00SlVHUUVkcXdFbTNNRzBQbmFpcCtkWUhJRnA0bzZ5NGUK",
      "endpoints": [
        "https://github.com/Gyeemi/InvoraLite/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
